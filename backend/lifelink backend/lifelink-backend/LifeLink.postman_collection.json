{
	"info": {
		"_postman_id": "ab7a22cc-c309-482a-a719-7ea5ca5282cf",
		"name": "LifeLink API v0",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Request OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"+1234567890\",\n    \"fullName\": \"John Doe\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/request-otp",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"request-otp"
							]
						}
					},
					"response": []
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"+1234567890\",\n    \"otpCode\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/verify-otp",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"auth",
								"verify-otp"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Discovery",
			"item": [
				{
					"name": "Find User by Code",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/discovery/LL-ABC12",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"discovery",
								"LL-ABC12"
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Get User Profile",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/users/{{userId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"{{userId}}"
							]
						}
					},
					"response": []
				},
				{
					"name": "Update User Info",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"dynamicInfo\": {\n        \"Blood Type\": \"O+\",\n        \"Emergency Contact\": \"+9876543210\"\n    },\n    \"publicFields\": [\n        \"Blood Type\"\n    ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/{{userId}}/meta-info",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"{{userId}}",
								"meta-info"
							]
						}
					},
					"response": []
				},
				{
					"name": "Download QR Code",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/users/{{userId}}/qr-code",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"users",
								"{{userId}}",
								"qr-code"
							]
						}
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "jwtToken",
			"value": "YOUR_JWT_TOKEN_HERE"
		},
		{
			"key": "userId",
			"value": "YOUR_USER_UUID_HERE"
		}
	]
}

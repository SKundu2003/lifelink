						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"johndoe\",\n    \"email\": \"john@example.com\",\n    \"fullName\": \"John Doe\",\n    \"phone\": \"+1234567890\",\n    \"isMinor\": false,\n    \"dynamicInfo\": {\n        \"bloodType\": \"O+\",\n        \"allergies\": \"Peanuts\",\n        \"emergencyContact\": \"Jane Doe (+0987654321)\"\n    }\n}"
						},
						"url": {
							"raw": "http://localhost:8080/api/users",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [

								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"dynamicInfo\": {\n        \"bloodType\": \"O+\",\n        \"allergies\": \"Peanuts, Pollen\",\n        \"medications\": \"None\"\n    }\n}"
						},
						"url": {
							"raw": "http://localhost:8080/api/users/{{userId}}/meta-info",
							"protocol": "http",
							"host": [
								"localhost"
							],
							"port": "8080",
							"path": [
